<Page
    x:Class="PocketTavern.UWP.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PocketTavern.UWP.Controls"
    Background="{StaticResource BackgroundDeepBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: back | avatar | name | menu -->
        <Grid Grid.Row="0" Background="{StaticResource BackgroundSurfaceBrush}" Padding="4,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="44" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextPrimaryBrush}" Click="OnBackClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>
            <Border Grid.Column="1" Width="36" Height="36" CornerRadius="18"
                    Background="{StaticResource AccentPrimaryBrush}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Image x:Name="AvatarImage" Stretch="UniformToFill" Visibility="Collapsed" />
                    <TextBlock x:Name="AvatarInitial"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="16" Foreground="White" FontWeight="Bold" />
                </Grid>
            </Border>
            <TextBlock Grid.Column="2" x:Name="CharacterNameLabel"
                       Style="{StaticResource BodyTextStyle}" FontSize="16" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="8,0" />
            <Button Grid.Column="3" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="20" />
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Chat History" Click="OnChatHistoryClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE81C;" FontFamily="Segoe MDL2 Assets" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="New Chat" Click="OnNewChatClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE710;" FontFamily="Segoe MDL2 Assets" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Character Settings" Click="OnCharacterSettingsClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE115;" FontFamily="Segoe MDL2 Assets" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Edit Character" Click="OnEditCharacterClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE70F;" FontFamily="Segoe MDL2 Assets" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Upload Background" Click="OnUploadBackgroundClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8B9;" FontFamily="Segoe MDL2 Assets" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="ClearBackgroundItem" Text="Clear Background" Click="OnClearBackgroundClick" Foreground="#FFE74C3C" Visibility="Collapsed">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Image Gallery" Click="OnImageGalleryClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE722;" FontFamily="Segoe MDL2 Assets" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Debug Log" Click="OnDebugLogClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xEBE8;" FontFamily="Segoe MDL2 Assets" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Clear Chat" Click="OnClearChatClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Delete Chat" Click="OnDeleteChatClick" Foreground="#FFE74C3C">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#FFE74C3C" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Delete Character" Click="OnDeleteCharacterClick" Foreground="#FFE74C3C">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#FFE74C3C" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <!-- Typing indicator overlay — sits at bottom of message area, shown during generation -->
        <Border Grid.Row="1" x:Name="TypingIndicator"
                VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Margin="16,0,0,8"
                Visibility="Collapsed">
            <controls:SpacedPanel Orientation="Horizontal" Spacing="6">
                <Border Background="{StaticResource AiBubbleBrush}"
                        CornerRadius="4,12,12,12" Padding="12,8">
                    <controls:SpacedPanel Orientation="Horizontal" Spacing="2">
                        <TextBlock x:Name="TypingDot1" Text="●" FontSize="8"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="TypingDot2" Text="●" FontSize="8"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Opacity="0.4" />
                        <TextBlock x:Name="TypingDot3" Text="●" FontSize="8"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Opacity="0.2" />
                    </controls:SpacedPanel>
                </Border>
            </controls:SpacedPanel>
        </Border>

                <!-- Background image (per-character) -->
        <Image Grid.Row="1" x:Name="ChatBackground" Stretch="UniformToFill" Opacity="0.15" Visibility="Collapsed" />

        <!-- Messages -->
        <ListView Grid.Row="1" x:Name="MessagesList"
                  SelectionMode="None"
                  Background="Transparent"
                  Padding="8,4"
                  ItemContainerStyle="{StaticResource MessageListItemStyle}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,6" RightTapped="OnMessageRightTapped">
                        <!-- AI message: left side -->
                        <StackPanel HorizontalAlignment="Left" MaxWidth="300"
                                    Visibility="{Binding IsUser, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding SenderName}"
                                       Style="{StaticResource SubtitleTextStyle}"
                                       FontSize="11" Margin="4,0,0,2" />
                            <Border Background="{StaticResource AiBubbleBrush}"
                                    CornerRadius="4,12,12,12" Padding="12,10">
                                <controls:MarkdownTextBlock Text="{Binding Content}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextFontSize="14" />
                            </Border>
                            <!-- Swipe indicators -->
                            <Grid Margin="4,2,0,0" Visibility="{Binding SwipeCount, Converter={StaticResource IntGreaterThanOneToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Opacity="0.6" VerticalAlignment="Center" />
                                    <TextBlock FontSize="10" VerticalAlignment="Center" Margin="4,0"
                                               Foreground="{StaticResource TextSecondaryBrush}">
                                        <Run Text="{Binding CurrentSwipeIndex}" /><Run Text="/" /><Run Text="{Binding SwipeCount}" />
                                    </TextBlock>
                                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Opacity="0.6" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        <!-- User message: right side -->
                        <StackPanel HorizontalAlignment="Right" MaxWidth="300"
                                    Visibility="{Binding IsUser, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="You" Style="{StaticResource SubtitleTextStyle}"
                                       FontSize="11" HorizontalAlignment="Right" Margin="0,0,4,2" />
                            <Border Background="{StaticResource UserBubbleBrush}"
                                    CornerRadius="12,4,12,12" Padding="12,10">
                                <controls:MarkdownTextBlock Text="{Binding Content}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextFontSize="14" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Regenerate / Continue buttons -->
        <controls:SpacedPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,4" Spacing="12">
            <Button x:Name="RegenerateButton" Click="OnRegenerateClick"
                    Background="{StaticResource BackgroundCardBrush}"
                    Foreground="{StaticResource AccentPrimaryBrush}"
                    BorderBrush="{StaticResource AccentPrimaryBrush}" BorderThickness="1"
                    Padding="16,8">
                <controls:SpacedPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" />
                    <TextBlock Text="Regenerate" FontSize="13" VerticalAlignment="Center" />
                </controls:SpacedPanel>
            </Button>
            <Button x:Name="ContinueButton" Click="OnContinueClick"
                    Background="{StaticResource BackgroundCardBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource BackgroundCardBrush}" BorderThickness="1"
                    Padding="16,8">
                <controls:SpacedPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" />
                    <TextBlock Text="Continue" FontSize="13" VerticalAlignment="Center" />
                </controls:SpacedPanel>
            </Button>
        </controls:SpacedPanel>

        <!-- API indicator bar -->
        <Border Grid.Row="3" x:Name="ApiIndicatorBar"
                Background="{StaticResource BackgroundSurfaceBrush}"
                Padding="16,4" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="ApiNameLabel"
                           Foreground="{StaticResource AccentPrimaryBrush}"
                           FontSize="11" VerticalAlignment="Center" />
                <TextBlock Text=" · " Style="{StaticResource SubtitleTextStyle}"
                           FontSize="11" VerticalAlignment="Center" />
                <TextBlock x:Name="ModelNameLabel"
                           Style="{StaticResource SubtitleTextStyle}"
                           FontSize="11" VerticalAlignment="Center"
                           MaxWidth="240" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <!-- Quick Reply bar (Row 4) -->
        <Border x:Name="QuickReplyBar" Grid.Row="4"
                Background="{StaticResource BackgroundSurfaceBrush}"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Scrollable button row — collapses when user hides it -->
                <ScrollViewer x:Name="QuickReplyScroll"
                              Grid.Column="0"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Enabled"
                              VerticalScrollMode="Disabled"
                              Visibility="Collapsed">
                    <controls:SpacedPanel x:Name="QuickReplyPanel"
                                Orientation="Horizontal"
                                Spacing="6"
                                Margin="8,6" />
                </ScrollViewer>

                <!-- Toggle chevron — always visible when bar is shown -->
                <Button x:Name="QuickReplyToggleBtn" Grid.Column="1"
                        Background="Transparent" BorderThickness="0"
                        Padding="8,6"
                        Click="OnQuickReplyToggleClick"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="QuickReplyChevron"
                               Text="&#xE70E;"
                               FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>
            </Grid>
        </Border>

        <!-- Input area -->
        <Grid Grid.Row="5" Background="{StaticResource BackgroundSurfaceBrush}" Padding="8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="MessageInput"
                     PlaceholderText="Type a message..."
                     Style="{StaticResource DarkTextBoxStyle}"
                     AcceptsReturn="False"
                     InputScope="Text"
                     KeyDown="OnInputKeyDown"
                     GotFocus="OnInputGotFocus" />
            <Button Grid.Column="1" x:Name="StopButton"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource AccentPrimaryBrush}"
                    Margin="4,0" Visibility="Collapsed" Click="OnStopClick">
                <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="22" />
            </Button>
            <Button Grid.Column="2" x:Name="SendButton" Click="OnSendClick"
                    Width="44" Height="44"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="4,0,0,0">
                <Border Width="44" Height="44" CornerRadius="22"
                        Background="{StaticResource AccentPrimaryBrush}">
                    <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </Button>
        </Grid>
    </Grid>
</Page>
