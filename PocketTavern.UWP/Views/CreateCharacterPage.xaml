<Page
    x:Class="PocketTavern.UWP.Views.CreateCharacterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PocketTavern.UWP.Controls"
    Background="{StaticResource BackgroundDeepBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource BackgroundSurfaceBrush}" Padding="4,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextPrimaryBrush}" Click="OnBackClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>
            <TextBlock Grid.Column="1" Text="Create Character" Style="{StaticResource TitleTextStyle}"
                       VerticalAlignment="Center" Margin="4,0" />
            <!-- Import PNG card button -->
            <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource AccentPrimaryBrush}"
                    Margin="0,0,4,0" Click="OnImportPngClick"
                    ToolTipService.ToolTip="Import character card (.png)">
                <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="20" />
            </Button>
            <Button Grid.Column="3" Style="{StaticResource AccentButtonStyle}"
                    Margin="0,0,8,0" Click="OnSaveClick">
                <controls:SpacedPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="Save" VerticalAlignment="Center" />
                </controls:SpacedPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="16">
            <StackPanel>

                <!-- Avatar picker -->
                <Button Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Center" Margin="0,16,0,0"
                        Click="OnAvatarClick">
                    <Grid>
                        <Border Width="96" Height="96" CornerRadius="48"
                                Background="{StaticResource BackgroundCardBrush}">
                            <Grid>
                                <Image x:Name="AvatarImage" Stretch="UniformToFill"
                                       Visibility="Collapsed" />
                                <TextBlock x:Name="AvatarInitial" Text="?"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="42" FontWeight="Bold"
                                           Foreground="{StaticResource AccentPrimaryBrush}" />
                            </Grid>
                        </Border>
                        <!-- Camera overlay -->
                        <Border Width="32" Height="32" CornerRadius="16"
                                Background="{StaticResource AccentPrimaryBrush}"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="White" />
                        </Border>
                    </Grid>
                </Button>

                <!-- Name field -->
                <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,16,0,0">
                    <controls:SpacedPanel Spacing="6">
                        <TextBlock Text="Name *" Style="{StaticResource SubtitleTextStyle}" />
                        <TextBox x:Name="NameBox" Style="{StaticResource DarkTextBoxStyle}"
                                 PlaceholderText="Character name"
                                 TextChanged="OnNameChanged" />
                    </controls:SpacedPanel>
                </Border>

                <!-- Description -->
                <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,8,0,0">
                    <controls:SpacedPanel Spacing="6">
                        <TextBlock Text="Description" Style="{StaticResource SubtitleTextStyle}" />
                        <TextBox x:Name="DescBox" Style="{StaticResource DarkTextBoxStyle}"
                                 PlaceholderText="Character description, background, appearance…"
                                 AcceptsReturn="True" Height="80" />
                    </controls:SpacedPanel>
                </Border>

                <!-- Personality -->
                <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,8,0,0">
                    <controls:SpacedPanel Spacing="6">
                        <TextBlock Text="Personality" Style="{StaticResource SubtitleTextStyle}" />
                        <TextBox x:Name="PersonalityBox" Style="{StaticResource DarkTextBoxStyle}"
                                 PlaceholderText="Personality traits, speech style…"
                                 AcceptsReturn="True" Height="60" />
                    </controls:SpacedPanel>
                </Border>

                <!-- Scenario -->
                <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,8,0,0">
                    <controls:SpacedPanel Spacing="6">
                        <TextBlock Text="Scenario" Style="{StaticResource SubtitleTextStyle}" />
                        <TextBox x:Name="ScenarioBox" Style="{StaticResource DarkTextBoxStyle}"
                                 PlaceholderText="Setting or scenario context"
                                 AcceptsReturn="True" Height="60" />
                    </controls:SpacedPanel>
                </Border>

                <!-- First Message -->
                <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,8,0,0">
                    <controls:SpacedPanel Spacing="6">
                        <TextBlock Text="First Message" Style="{StaticResource SubtitleTextStyle}" />
                        <TextBox x:Name="FirstMsgBox" Style="{StaticResource DarkTextBoxStyle}"
                                 PlaceholderText="Opening message from the character"
                                 AcceptsReturn="True" Height="80" />
                    </controls:SpacedPanel>
                </Border>

                <!-- System Prompt -->
                <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,8,0,0">
                    <controls:SpacedPanel Spacing="6">
                        <TextBlock Text="System Prompt" Style="{StaticResource SubtitleTextStyle}" />
                        <TextBox x:Name="SysPromptBox" Style="{StaticResource DarkTextBoxStyle}"
                                 PlaceholderText="Custom system prompt (optional)"
                                 AcceptsReturn="True" Height="60" />
                    </controls:SpacedPanel>
                </Border>

                <!-- Tags -->
                <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,8,0,0">
                    <controls:SpacedPanel Spacing="6">
                        <TextBlock Text="Tags" Style="{StaticResource SubtitleTextStyle}" />
                        <TextBox x:Name="TagsBox" Style="{StaticResource DarkTextBoxStyle}"
                                 PlaceholderText="fantasy, female, elf (comma-separated)" />
                    </controls:SpacedPanel>
                </Border>

                <Border Height="32" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
