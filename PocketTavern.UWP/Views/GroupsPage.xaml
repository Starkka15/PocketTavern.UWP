<Page
    x:Class="PocketTavern.UWP.Views.GroupsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundDeepBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource BackgroundSurfaceBrush}" Padding="4,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Click="BackButton_Click">
                <TextBlock Text="&#xE830;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </Button>
            <TextBlock Grid.Column="1" Text="Groups" VerticalAlignment="Center"
                       Style="{StaticResource TitleTextStyle}" />
        </Grid>

        <!-- Content: not yet supported message -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="24">
            <TextBlock Text="&#xE902;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Text="Group chats are not yet supported in standalone mode."
                       Margin="0,12,0,0"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- Error toast -->
        <Border x:Name="ErrorBorder" Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Background="{StaticResource AccentPrimaryBrush}" CornerRadius="8" Padding="12,8" Margin="16"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorText" Foreground="White" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Page>
