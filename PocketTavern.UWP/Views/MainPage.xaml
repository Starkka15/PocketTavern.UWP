<Page
    x:Class="PocketTavern.UWP.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PocketTavern.UWP.Controls"
    Background="{StaticResource BackgroundDeepBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Hidden JS extension sandbox — zero-size, opacity 0 so JS still runs -->
        <WebView x:Name="ExtSandbox" Grid.Row="0"
                 Width="1" Height="1"
                 Opacity="0" IsHitTestVisible="False" />

        <!--
            Optional theme background image / GIF (sand_and_sea etc.)
            Sits behind everything, spans all rows.
        -->
        <Image x:Name="ThemeBackground"
               Grid.Row="0" Grid.RowSpan="3"
               Stretch="UniformToFill"
               Opacity="0.65"
               Visibility="Collapsed" />

        <!--
            Particle canvas — spans all rows, renders above background but below UI.
            Particles are created/animated in code-behind via DispatcherTimer.
        -->
        <Canvas x:Name="ParticleCanvas"
                Grid.Row="0" Grid.RowSpan="3"
                IsHitTestVisible="False" />

        <!-- ══ Header ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Background="Transparent" Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo (custom from theme, or default text) -->
            <Image x:Name="ThemeLogo"
                   Grid.Column="0"
                   Source="ms-appx:///Assets/logo_pockettavern.png"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   MaxHeight="56" Visibility="Visible" />
            <TextBlock x:Name="DefaultLogo"
                       Grid.Column="0"
                       Text="PocketTavern"
                       Foreground="{StaticResource AccentPrimaryBrush}"
                       FontSize="28" FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed" />
        </Grid>

        <!-- ══ Navigation Cards ════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <controls:SpacedPanel VerticalAlignment="Center" Margin="16,20,16,20" Spacing="16">

                <!-- Characters -->
                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="0"
                        Click="OnCharactersClick">
                    <Border Background="{StaticResource BackgroundCardBrush}" Opacity="0.85"
                            CornerRadius="16"
                            BorderBrush="{StaticResource AccentPrimaryBrush}" BorderThickness="1.5">
                        <Grid Padding="20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Width="64" Height="64" Fill="{StaticResource AccentPrimaryBrush}" Opacity="0.10" />
                                <Ellipse Width="46" Height="46" Fill="{StaticResource AccentPrimaryBrush}" Opacity="0.30" />
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentPrimaryBrush}" />
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                <TextBlock Text="Characters" Style="{StaticResource TitleTextStyle}" FontSize="18" />
                                <TextBlock Text="Browse and chat with your characters"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           MaxLines="1" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

                <!-- Recent Chats -->
                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="0"
                        Click="OnRecentChatsClick">
                    <Border Background="{StaticResource BackgroundCardBrush}" Opacity="0.85"
                            CornerRadius="16"
                            BorderBrush="{StaticResource AccentPrimaryBrush}" BorderThickness="1.5">
                        <Grid Padding="20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Width="64" Height="64" Fill="{StaticResource AccentPrimaryBrush}" Opacity="0.10" />
                                <Ellipse Width="46" Height="46" Fill="{StaticResource AccentPrimaryBrush}" Opacity="0.30" />
                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentPrimaryBrush}" />
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                <TextBlock Text="Recent Chats" Style="{StaticResource TitleTextStyle}" FontSize="18" />
                                <TextBlock Text="Continue your recent conversations"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           MaxLines="1" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

                <!-- Create Character -->
                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="0"
                        Click="OnCreateCharacterClick">
                    <Border Background="{StaticResource BackgroundCardBrush}" Opacity="0.85"
                            CornerRadius="16"
                            BorderBrush="{StaticResource AccentPrimaryBrush}" BorderThickness="1.5">
                        <Grid Padding="20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Width="64" Height="64" Fill="{StaticResource AccentPrimaryBrush}" Opacity="0.10" />
                                <Ellipse Width="46" Height="46" Fill="{StaticResource AccentPrimaryBrush}" Opacity="0.30" />
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentPrimaryBrush}" />
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                <TextBlock Text="Create Character" Style="{StaticResource TitleTextStyle}" FontSize="18" />
                                <TextBlock Text="Design a new character from scratch"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           MaxLines="1" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

                <!-- Card Search (CharaVault) -->
                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="0"
                        Click="OnCharaVaultClick">
                    <Border Background="{StaticResource BackgroundCardBrush}" Opacity="0.85"
                            CornerRadius="16"
                            BorderBrush="{StaticResource AccentPrimaryBrush}" BorderThickness="1.5">
                        <Grid Padding="20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Width="64" Height="64" Fill="{StaticResource AccentPrimaryBrush}" Opacity="0.10" />
                                <Ellipse Width="46" Height="46" Fill="{StaticResource AccentPrimaryBrush}" Opacity="0.30" />
                                <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentPrimaryBrush}" />
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                <TextBlock Text="Card Search" Style="{StaticResource TitleTextStyle}" FontSize="18" />
                                <TextBlock Text="Browse characters from CharaVault and Chub.ai"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           MaxLines="1" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

                <!-- Settings -->
                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="0"
                        Click="OnSettingsClick">
                    <Border Background="{StaticResource BackgroundCardBrush}" Opacity="0.85"
                            CornerRadius="16"
                            BorderBrush="{StaticResource AccentPrimaryBrush}" BorderThickness="1.5">
                        <Grid Padding="20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Width="64" Height="64" Fill="{StaticResource AccentPrimaryBrush}" Opacity="0.10" />
                                <Ellipse Width="46" Height="46" Fill="{StaticResource AccentPrimaryBrush}" Opacity="0.30" />
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentPrimaryBrush}" />
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                <TextBlock Text="Settings" Style="{StaticResource TitleTextStyle}" FontSize="18" />
                                <TextBlock Text="Configure server, API and app preferences"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           MaxLines="1" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

            </controls:SpacedPanel>
        </ScrollViewer>

        <!-- ══ Connection status bar ═══════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource BackgroundSurfaceBrush}"
                Opacity="0.92" Padding="16,8">
            <TextBlock x:Name="ConnectionLabel"
                       Style="{StaticResource SubtitleTextStyle}"
                       HorizontalAlignment="Center" />
        </Border>

    </Grid>
</Page>
