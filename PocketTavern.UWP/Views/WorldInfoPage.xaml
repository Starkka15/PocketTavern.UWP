<Page
    x:Class="PocketTavern.UWP.Views.WorldInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundDeepBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource BackgroundSurfaceBrush}" Padding="4,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextPrimaryBrush}" Click="OnBackClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>
            <TextBlock Grid.Column="1" Text="World Info / Lorebooks" Style="{StaticResource TitleTextStyle}"
                       VerticalAlignment="Center" Margin="4,0" />
            <Button Grid.Column="2" Margin="0,0,8,0" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource AccentPrimaryBrush}" Click="OnRefreshClick">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>
        </Grid>

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" Grid.Row="1" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="&#xE736;" FontFamily="Segoe MDL2 Assets" FontSize="64"
                       HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Text="No lorebooks found" Style="{StaticResource SubtitleTextStyle}"
                       HorizontalAlignment="Center" Margin="0,12,0,0" FontSize="16" />
            <TextBlock Text="Add lorebooks in SillyTavern to see them here"
                       Style="{StaticResource SubtitleTextStyle}"
                       HorizontalAlignment="Center" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Lorebook list -->
        <ListView Grid.Row="1" x:Name="WorldsList"
                  SelectionMode="None" Background="Transparent" Padding="0,8,0,8"
                  IsItemClickEnabled="True" ItemClick="OnLorebookClicked">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="16,4" Background="{StaticResource BackgroundCardBrush}"
                            CornerRadius="12" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="&#xE736;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                       Foreground="{StaticResource AccentPrimaryBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" />

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding EntryCount}"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           Margin="0,2,0,0" />
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
