<Page
    x:Class="PocketTavern.UWP.Views.CharactersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundDeepBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource BackgroundSurfaceBrush}" Padding="4,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="44" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextPrimaryBrush}" Click="OnBackClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>

            <!-- Tab dropdown title -->
            <Button Grid.Column="1" x:Name="TabDropdownButton"
                    Background="Transparent" BorderThickness="0"
                    HorizontalAlignment="Left" VerticalAlignment="Center" Padding="4,0">
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Characters" Click="OnTabCharactersClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE77B;" FontFamily="Segoe MDL2 Assets" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Groups" Click="OnTabGroupsClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE902;" FontFamily="Segoe MDL2 Assets" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TabTitleText" Text="Characters"
                               Style="{StaticResource TitleTextStyle}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="&#xE972;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="4,3,0,0" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2" x:Name="CreateButton"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource AccentPrimaryBrush}" Click="OnCreateClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="22" />
            </Button>
            <Button Grid.Column="3" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextSecondaryBrush}" Click="OnRefreshClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>
        </Grid>

        <!-- Search (characters tab only) -->
        <TextBox Grid.Row="1" x:Name="SearchBox" PlaceholderText="Search characters..."
                 Style="{StaticResource DarkTextBoxStyle}" Margin="12,8"
                 TextChanged="OnSearchChanged" />

        <!-- Characters list -->
        <ListView Grid.Row="2" x:Name="CharactersList"
                  SelectionMode="None" IsItemClickEnabled="True"
                  ItemClick="OnCharacterClicked"
                  Background="Transparent"
                  ItemContainerStyle="{StaticResource MessageListItemStyle}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>
                        <!-- Avatar circle (image or initial letter) -->
                        <Border Width="48" Height="48" CornerRadius="24"
                                Background="{StaticResource BackgroundCardBrush}">
                            <Grid>
                                <Image Source="{Binding AvatarLocalPath}" Stretch="UniformToFill"
                                       Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock Text="{Binding Initial}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="22" Foreground="{StaticResource AccentSecondaryBrush}"
                                           FontWeight="Bold"
                                           Visibility="{Binding HasAvatar, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                            </Grid>
                        </Border>
                        <!-- Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="★" FontSize="12" Margin="6,2,0,0"
                                           Foreground="{StaticResource AccentSecondaryBrush}"
                                           Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Description}"
                                       Style="{StaticResource SubtitleTextStyle}"
                                       MaxLines="2" TextTrimming="CharacterEllipsis"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <!-- Context menu -->
                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Tag="{Binding}" Click="OnCharacterMenuClick">
                            <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Chat" Tag="{Binding}" Click="OnCharacterChatClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8BD;" FontFamily="Segoe MDL2 Assets" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Edit" Tag="{Binding}" Click="OnCharacterEditClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE70F;" FontFamily="Segoe MDL2 Assets" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Toggle Favorite" Tag="{Binding}" Click="OnCharacterFavoriteClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE734;" FontFamily="Segoe MDL2 Assets" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Delete" Tag="{Binding}" Click="OnCharacterDeleteClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Characters empty state -->
        <StackPanel Grid.Row="2" x:Name="EmptyState" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="32">
            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="64"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="No characters yet" Style="{StaticResource TitleTextStyle}"
                       HorizontalAlignment="Center" Margin="0,16,0,0" />
            <TextBlock Text="Tap + to create your first character"
                       Style="{StaticResource SubtitleTextStyle}"
                       HorizontalAlignment="Center" Margin="0,8,0,0" />
        </StackPanel>

        <!-- Groups panel (shown when Groups tab is active) -->
        <StackPanel Grid.Row="2" x:Name="GroupsPanel" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="24">
            <TextBlock Text="&#xE902;" FontFamily="Segoe MDL2 Assets" FontSize="64"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Group chats are not yet supported in standalone mode."
                       Margin="0,12,0,0"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- Bottom divider line -->
        <Rectangle Grid.Row="3" Height="1" Fill="{StaticResource BackgroundCardBrush}" />
    </Grid>
</Page>
