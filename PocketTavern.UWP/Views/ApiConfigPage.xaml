<Page
    x:Class="PocketTavern.UWP.Views.ApiConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PocketTavern.UWP.Controls"
    Background="{StaticResource BackgroundDeepBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource BackgroundSurfaceBrush}" Padding="4,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextPrimaryBrush}" Click="OnBackClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>
            <TextBlock Grid.Column="1" Text="API Configuration" Style="{StaticResource TitleTextStyle}"
                       VerticalAlignment="Center" Margin="4,0" />
            <Button Grid.Column="2" Style="{StaticResource AccentButtonStyle}"
                    Margin="0,0,8,0" Click="OnSaveClick">
                <controls:SpacedPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="Save" VerticalAlignment="Center" />
                </controls:SpacedPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="16">
            <StackPanel>

                <!-- Main API -->
                <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,0,0,0">
                    <controls:SpacedPanel Spacing="8">
                        <TextBlock Text="Main API" Style="{StaticResource SubtitleTextStyle}" />
                        <ComboBox x:Name="MainApiCombo" HorizontalAlignment="Stretch"
                                  Background="{StaticResource BackgroundSurfaceBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  SelectionChanged="OnMainApiChanged">
                            <ComboBoxItem x:Name="MainApiLocalItem"  Content="Local / Text Generation" />
                            <ComboBoxItem x:Name="MainApiChatItem"   Content="OpenAI-compatible (Chat)" />
                        </ComboBox>
                    </controls:SpacedPanel>
                </Border>

                <!-- Text Completion Backend (visible when Local) -->
                <Border x:Name="TextGenSection"
                        Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,8,0,0">
                    <controls:SpacedPanel Spacing="8">
                        <TextBlock Text="Text Completion Backend"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="Backend Type" Style="{StaticResource SubtitleTextStyle}" />
                        <ComboBox x:Name="TextGenTypeCombo" HorizontalAlignment="Stretch"
                                  Background="{StaticResource BackgroundSurfaceBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}">
                            <ComboBoxItem x:Name="TgKoboldCpp"    Content="KoboldCpp" />
                            <ComboBoxItem x:Name="TgLlamaCpp"     Content="llama.cpp" />
                            <ComboBoxItem x:Name="TgOoba"         Content="Text Generation WebUI (Ooba)" />
                            <ComboBoxItem x:Name="TgVllm"         Content="vLLM" />
                            <ComboBoxItem x:Name="TgAphrodite"    Content="Aphrodite" />
                            <ComboBoxItem x:Name="TgTabby"        Content="TabbyAPI" />
                            <ComboBoxItem x:Name="TgOllama"       Content="Ollama" />
                            <ComboBoxItem x:Name="TgTogetherAi"   Content="Together AI" />
                            <ComboBoxItem x:Name="TgInfermatic"   Content="Infermatic AI" />
                            <ComboBoxItem x:Name="TgOpenRouter"   Content="OpenRouter (Text)" />
                            <ComboBoxItem x:Name="TgFeatherless"  Content="Featherless" />
                            <ComboBoxItem x:Name="TgMancer"       Content="Mancer" />
                            <ComboBoxItem x:Name="TgDreamGen"     Content="DreamGen" />
                            <ComboBoxItem x:Name="TgHuggingFace"  Content="HuggingFace" />
                            <ComboBoxItem x:Name="TgGeneric"      Content="Generic OpenAI-compatible" />
                        </ComboBox>
                        <TextBlock Text="Server URL" Style="{StaticResource SubtitleTextStyle}" Margin="0,4,0,0" />
                        <TextBox x:Name="ApiServerBox" Style="{StaticResource DarkTextBoxStyle}"
                                 PlaceholderText="http://127.0.0.1:5001" />
                        <!-- Local model selection row -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="44" />
                            </Grid.ColumnDefinitions>
                            <controls:SpacedPanel Spacing="4">
                                <TextBlock Text="Model" Style="{StaticResource SubtitleTextStyle}" />
                                <ComboBox x:Name="LocalModelCombo" HorizontalAlignment="Stretch"
                                          Visibility="Collapsed"
                                          Background="{StaticResource BackgroundSurfaceBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          SelectionChanged="OnLocalModelComboChanged" />
                                <TextBox x:Name="LocalModelBox" Style="{StaticResource DarkTextBoxStyle}"
                                         PlaceholderText="Auto-detected from server" />
                            </controls:SpacedPanel>
                            <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                <Button Background="Transparent" BorderThickness="0"
                                        Foreground="{StaticResource AccentPrimaryBrush}"
                                        Padding="8" Click="OnRefreshModelsClick"
                                        x:Name="LocalRefreshButton">
                                    <TextBlock x:Name="LocalRefreshIcon" Text="&#xE72C;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                </Button>
                                <ProgressRing x:Name="LocalModelsLoadingRing" IsActive="False"
                                              Width="20" Height="20"
                                              Foreground="{StaticResource AccentPrimaryBrush}" />
                            </Grid>
                        </Grid>
                        <TextBlock x:Name="LocalModelCountLabel" Style="{StaticResource SubtitleTextStyle}"
                                   FontSize="11" Visibility="Collapsed" />
                    </controls:SpacedPanel>
                </Border>

                <!-- Chat Completion Provider (visible when OpenAI-compatible) -->
                <Border x:Name="ChatSection"
                        Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,8,0,0" Visibility="Collapsed">
                    <controls:SpacedPanel Spacing="8">
                        <TextBlock Text="Chat Completion Provider"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="Provider" Style="{StaticResource SubtitleTextStyle}" />
                        <ComboBox x:Name="ProviderCombo" HorizontalAlignment="Stretch"
                                  Background="{StaticResource BackgroundSurfaceBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  SelectionChanged="OnProviderChanged">
                            <ComboBoxItem x:Name="PvOpenAi"       Content="OpenAI" />
                            <ComboBoxItem x:Name="PvClaude"       Content="Anthropic Claude" />
                            <ComboBoxItem x:Name="PvOpenRouter"   Content="OpenRouter" />
                            <ComboBoxItem x:Name="PvNanoGpt"      Content="NanoGPT" />
                            <ComboBoxItem x:Name="PvDeepSeek"     Content="DeepSeek" />
                            <ComboBoxItem x:Name="PvMistral"      Content="Mistral AI" />
                            <ComboBoxItem x:Name="PvCohere"       Content="Cohere" />
                            <ComboBoxItem x:Name="PvPerplexity"   Content="Perplexity" />
                            <ComboBoxItem x:Name="PvGroq"         Content="Groq" />
                            <ComboBoxItem x:Name="PvMakerSuite"   Content="Google AI Studio" />
                            <ComboBoxItem x:Name="PvVertexAi"     Content="Google Vertex AI" />
                            <ComboBoxItem x:Name="PvAi21"         Content="AI21" />
                            <ComboBoxItem x:Name="PvXai"          Content="xAI (Grok)" />
                            <ComboBoxItem x:Name="PvFireworks"    Content="Fireworks AI" />
                            <ComboBoxItem x:Name="PvMoonshot"     Content="Moonshot" />
                            <ComboBoxItem x:Name="PvAimlApi"      Content="AIML API" />
                            <ComboBoxItem x:Name="PvPollinations"  Content="Pollinations (Free)" />
                            <ComboBoxItem x:Name="PvChutes"       Content="Chutes" />
                            <ComboBoxItem x:Name="PvElectronHub"  Content="ElectronHub" />
                            <ComboBoxItem x:Name="PvSiliconFlow"  Content="SiliconFlow" />
                            <ComboBoxItem x:Name="PvZai"          Content="Z.AI" />
                            <ComboBoxItem x:Name="PvAzure"        Content="Azure OpenAI" />
                            <ComboBoxItem x:Name="PvCustom"       Content="Custom OpenAI-compatible" />
                        </ComboBox>
                        <!-- Custom URL row, shown only when provider == custom -->
                        <StackPanel x:Name="CustomUrlRow" Visibility="Collapsed">
                            <TextBlock Text="Custom API URL" Style="{StaticResource SubtitleTextStyle}" Margin="0,4,0,4" />
                            <TextBox x:Name="CustomUrlBox" Style="{StaticResource DarkTextBoxStyle}"
                                     PlaceholderText="https://api.example.com/v1" />
                        </StackPanel>
                        <!-- Model row: dropdown when loaded, text field as fallback -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="44" />
                            </Grid.ColumnDefinitions>
                            <controls:SpacedPanel Spacing="4">
                                <TextBlock Text="Model" Style="{StaticResource SubtitleTextStyle}" />
                                <!-- Shown when models are loaded -->
                                <ComboBox x:Name="ModelCombo" HorizontalAlignment="Stretch"
                                          Visibility="Collapsed"
                                          Background="{StaticResource BackgroundSurfaceBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          SelectionChanged="OnModelComboChanged" />
                                <!-- Shown when no models loaded -->
                                <TextBox x:Name="ModelBox" Style="{StaticResource DarkTextBoxStyle}"
                                         PlaceholderText="Enter model name (e.g. gpt-4o)" />
                            </controls:SpacedPanel>
                            <!-- Refresh button -->
                            <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                <Button Background="Transparent" BorderThickness="0"
                                        Foreground="{StaticResource AccentPrimaryBrush}"
                                        Padding="8" Click="OnRefreshModelsClick"
                                        x:Name="RefreshModelsButton">
                                    <TextBlock x:Name="RefreshIcon" Text="&#xE72C;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                </Button>
                                <ProgressRing x:Name="ModelsLoadingRing" IsActive="False"
                                              Width="20" Height="20"
                                              Foreground="{StaticResource AccentPrimaryBrush}" />
                            </Grid>
                        </Grid>
                        <TextBlock x:Name="ModelCountLabel" Style="{StaticResource SubtitleTextStyle}"
                                   FontSize="11" Visibility="Collapsed" />
                    </controls:SpacedPanel>
                </Border>

                <!-- API Key -->
                <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,8,0,0">
                    <controls:SpacedPanel Spacing="8">
                        <TextBlock Text="API Key"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="44" />
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="ApiKeyBox" Grid.Column="0"
                                         PlaceholderText="sk-... (leave blank for local backends)" />
                            <TextBox x:Name="ApiKeyBoxVisible" Grid.Column="0"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     PlaceholderText="sk-... (leave blank for local backends)"
                                     Visibility="Collapsed" />
                            <Button Grid.Column="1" Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Click="OnToggleApiKeyVisibility">
                                <TextBlock x:Name="EyeIcon" Text="&#xE7B3;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="16" />
                            </Button>
                        </Grid>
                        <TextBlock Text="Used for OpenAI, Claude, OpenRouter, TabbyAPI and other authenticated backends."
                                   Style="{StaticResource SubtitleTextStyle}" FontSize="11" TextWrapping="Wrap" />
                    </controls:SpacedPanel>
                </Border>

                <!-- Test Connection -->
                <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="12"
                        Padding="16,12" Margin="0,8,0,16">
                    <controls:SpacedPanel Spacing="10">
                        <Button x:Name="TestButton" Content="Test Connection"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Click="OnTestConnectionClick" />
                        <TextBlock x:Name="ConnectionStatusLabel"
                                   Style="{StaticResource SubtitleTextStyle}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </controls:SpacedPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
