<Page
    x:Class="PocketTavern.UWP.Views.ExtensionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PocketTavern.UWP.Controls"
    Background="{StaticResource BackgroundDeepBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource BackgroundSurfaceBrush}" Padding="4,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextPrimaryBrush}" Click="OnBackClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>
            <TextBlock Grid.Column="1" Text="Extensions" Style="{StaticResource TitleTextStyle}"
                       VerticalAlignment="Center" Margin="4,0" />
        </Grid>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,8,0,32">

                <!-- ── Native Extensions ────────────────────────────────────── -->
                <TextBlock Text="NATIVE EXTENSIONS" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentPrimaryBrush}"
                           Margin="16,8,16,6" />

                <!-- Quick Reply -->
                <Border Margin="12,0,12,8" Background="{StaticResource BackgroundCardBrush}"
                        CornerRadius="10" Padding="16,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="{StaticResource AccentPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="Quick Reply" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Preset message buttons shown above the chat input."
                                           Style="{StaticResource SubtitleTextStyle}" Margin="0,2,0,0" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2" x:Name="QuickReplyToggle"
                                          VerticalAlignment="Center" Margin="0,0,-8,0"
                                          Toggled="OnQuickReplyToggled" />
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BackgroundSurfaceBrush}" Margin="0,10,0,6" />
                        <Button HorizontalAlignment="Right" Background="Transparent"
                                BorderThickness="0" Foreground="{StaticResource AccentPrimaryBrush}"
                                Click="OnQuickReplySettingsClick" Padding="0">
                            <controls:SpacedPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Settings" FontSize="13" />
                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           VerticalAlignment="Center" />
                            </controls:SpacedPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Regex -->
                <Border Margin="12,0,12,8" Background="{StaticResource BackgroundCardBrush}"
                        CornerRadius="10" Padding="16,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="{StaticResource AccentPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="Regex" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Find-and-replace rules applied to AI output or your messages."
                                           Style="{StaticResource SubtitleTextStyle}" Margin="0,2,0,0" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2" x:Name="RegexToggle"
                                          VerticalAlignment="Center" Margin="0,0,-8,0"
                                          Toggled="OnRegexToggled" />
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BackgroundSurfaceBrush}" Margin="0,10,0,6" />
                        <Button HorizontalAlignment="Right" Background="Transparent"
                                BorderThickness="0" Foreground="{StaticResource AccentPrimaryBrush}"
                                Click="OnRegexSettingsClick" Padding="0">
                            <controls:SpacedPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Settings" FontSize="13" />
                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           VerticalAlignment="Center" />
                            </controls:SpacedPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Token Counter -->
                <Border Margin="12,0,12,8" Background="{StaticResource BackgroundCardBrush}"
                        CornerRadius="10" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE8EF;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                   Foreground="{StaticResource AccentPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                            <TextBlock Text="Token Counter" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Show estimated token count while you type (~4 chars per token)."
                                       Style="{StaticResource SubtitleTextStyle}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" x:Name="TokenCounterToggle"
                                      VerticalAlignment="Center" Margin="0,0,-8,0"
                                      Toggled="OnTokenCounterToggled" />
                    </Grid>
                </Border>

                <!-- ── JavaScript Extensions ────────────────────────────────── -->
                <Grid Margin="16,12,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="JAVASCRIPT EXTENSIONS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource AccentPrimaryBrush}"
                            Click="OnInstallExtensionClick"
                            ToolTipService.ToolTip="Install extension">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="20" />
                    </Button>
                </Grid>

                <!-- JS extension list (built programmatically in code-behind) -->
                <StackPanel x:Name="JsExtensionsList" />

                <!-- Empty state -->
                <StackPanel x:Name="JsEmptyState" Visibility="Collapsed"
                            HorizontalAlignment="Center" Margin="32,16">
                    <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="40"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="No JavaScript extensions installed"
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,4"
                               TextWrapping="Wrap" TextAlignment="Center" />
                    <TextBlock Text="Tap + to install from a URL or .js / .zip file"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
