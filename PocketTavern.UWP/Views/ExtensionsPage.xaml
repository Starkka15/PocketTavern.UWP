<Page
    x:Class="PocketTavern.UWP.Views.ExtensionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundDeepBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource BackgroundSurfaceBrush}" Padding="4,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextPrimaryBrush}" Click="OnBackClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>
            <TextBlock Grid.Column="1" Text="Extensions" Style="{StaticResource TitleTextStyle}"
                       VerticalAlignment="Center" Margin="4,0" />
            <Button Grid.Column="2" Margin="0,0,8,0" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource AccentPrimaryBrush}" Click="OnRefreshClick">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>
        </Grid>

        <!-- Extensions list -->
        <ListView Grid.Row="1" x:Name="ExtList"
                  SelectionMode="None" Background="Transparent" Padding="0,4,0,4">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="16,4" Background="{StaticResource BackgroundCardBrush}"
                            CornerRadius="12" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="36" Height="36" CornerRadius="18"
                                    Background="#3356E9A4">
                                <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#56E9A4" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Description}"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           MaxLines="2" TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0" />
                            </StackPanel>

                            <ToggleSwitch Grid.Column="2" IsOn="{Binding Enabled, Mode=TwoWay}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          VerticalAlignment="Center" Margin="0,0,-8,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
