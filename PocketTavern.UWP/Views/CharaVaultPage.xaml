<Page
    x:Class="PocketTavern.UWP.Views.CharaVaultPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundDeepBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource BackgroundSurfaceBrush}" Padding="4,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="44" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextPrimaryBrush}" Click="OnBackClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>
            <TextBlock Grid.Column="1" Text="Card Search" Style="{StaticResource TitleTextStyle}"
                       VerticalAlignment="Center" Margin="4,0" />
            <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextSecondaryBrush}" Click="OnConfigureClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    ToolTipService.ToolTip="Configure server URL">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
            </Button>
        </Grid>

        <!-- Search bar -->
        <Grid Grid.Row="1" Background="{StaticResource BackgroundSurfaceBrush}"
              Padding="12,8,12,12" BorderThickness="0,1,0,0"
              BorderBrush="{StaticResource BackgroundCardBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0"
                     Style="{StaticResource DarkTextBoxStyle}"
                     PlaceholderText="Search characters…"
                     KeyDown="OnSearchKeyDown" />
            <Button Grid.Column="1" Margin="8,0,0,0"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnSearchClick">
                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
        </Grid>

        <!-- Results list -->
        <Grid Grid.Row="2">
            <!-- Loading indicator -->
            <ProgressRing x:Name="LoadingRing" IsActive="False"
                          Foreground="{StaticResource AccentPrimaryBrush}"
                          Width="48" Height="48"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Status / empty state -->
            <StackPanel x:Name="EmptyState" Visibility="Visible"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="56"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock x:Name="StatusLabel" Text="Search for characters on CharaVault"
                           Style="{StaticResource SubtitleTextStyle}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>

            <!-- Results -->
            <ListView x:Name="ResultsList" Visibility="Collapsed"
                      SelectionMode="None" IsItemClickEnabled="True"
                      ItemClick="OnCardClicked"
                      Background="Transparent" Padding="0,4,0,4">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="16,10" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Avatar circle -->
                            <Border Width="48" Height="48" CornerRadius="24"
                                    Background="{StaticResource BackgroundCardBrush}">
                                <Grid>
                                    <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill" />
                                    <TextBlock Text="{Binding Initial}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="22" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentPrimaryBrush}" />
                                </Grid>
                            </Border>

                            <!-- Name + tagline -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Author}"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           FontSize="11" Margin="0,1,0,0" />
                                <TextBlock Text="{Binding Tagline}"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           MaxLines="2" TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0" />
                            </StackPanel>

                            <!-- Import button -->
                            <Button Grid.Column="2" VerticalAlignment="Center"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Tag="{Binding}" Click="OnImportClick"
                                    Padding="12,6">
                                <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Load more / status bar -->
        <Border Grid.Row="3" Background="{StaticResource BackgroundSurfaceBrush}" Padding="16,8">
            <Grid>
                <TextBlock x:Name="FooterStatus" Style="{StaticResource SubtitleTextStyle}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Button x:Name="LoadMoreButton" Content="Load More"
                        HorizontalAlignment="Center"
                        Style="{StaticResource AccentButtonStyle}"
                        Visibility="Collapsed"
                        Click="OnLoadMoreClick" />
            </Grid>
        </Border>
    </Grid>
</Page>
